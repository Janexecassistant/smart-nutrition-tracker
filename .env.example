# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/snt
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/snt

# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis (Upstash)
UPSTASH_REDIS_URL=http://localhost:6379
UPSTASH_REDIS_TOKEN=

# Typesense
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=your-typesense-key

# Open Food Facts (no key needed, but rate limit config)
OFF_API_URL=https://world.openfoodfacts.org/api/v2

# App
API_PORT=3001
WEB_PORT=3000
NODE_ENV=development
JWT_SECRET=your-jwt-secret-change-in-production
