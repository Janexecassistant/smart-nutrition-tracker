    "@supabase/supabase-js": "^2.47.0",
    "@snt/shared": "*",
    "@snt/db": "*",
    "@snt/nutrition": "*",
    "drizzle-orm": "^0.38.0",
    "typesense": "^2.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  }
}
