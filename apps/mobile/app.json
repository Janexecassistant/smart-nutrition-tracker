{
  "expo": {
    "name": "Smart Nutrition Tracker",
    "slug": "smart-nutrition-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "snt",
    "newArchEnabled": true,

    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#22c55e"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartnutritiontracker.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Smart Nutrition Tracker uses the camera to scan food barcodes for quick nutrition lookup.",
        "NSHealthShareUsageDescription": "Smart Nutrition Tracker reads your health data to sync weight, steps, and activity.",
        "NSHealthUpdateUsageDescription": "Smart Nutrition Tracker writes nutrition and weight data to Apple Health.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "associatedDomains": ["applinks:smartnutritiontracker.com"]
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#22c55e"
      },
      "package": "com.smartnutritiontracker.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "smartnutritiontracker.com",
              "pathPrefix": "/app"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },

    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Smart Nutrition Tracker uses the camera to scan food barcodes."
        }
      ]
    ],

    "owner": "smartnutritiontracker"
  }
}
