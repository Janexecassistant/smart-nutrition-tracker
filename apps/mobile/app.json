{
  "expo": {
    "name": "Smart Nutrition Tracker",
    "slug": "smart-nutrition-tracker",
    "version": "1.0.1",
    "platforms": ["ios", "android"],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "snt",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#059669"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartnutritiontracker.app",
      "buildNumber": "3",
      "infoPlist": {
        "NSCameraUsageDescription": "Smart Nutrition Tracker uses the camera to scan food barcodes for quick nutrition lookup.",
        "NSHealthShareUsageDescription": "Smart Nutrition Tracker reads your health data to sync weight, steps, and activity.",
        "NSHealthUpdateUsageDescription": "Smart Nutrition Tracker writes nutrition and weight data to Apple Health.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:smartnutritiontracker.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#059669"
      },
      "package": "com.smartnutritiontracker.app",
      "versionCode": 3,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "smartnutritiontracker.com",
              "pathPrefix": "/app"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Smart Nutrition Tracker uses the camera to scan food barcodes."
        }
      ],
      "expo-font",
      "expo-router",
      "expo-web-browser"
    ],
    "extra": {
      "EXPO_PUBLIC_API_URL": "https://sntapi-production.up.railway.app",
      "EXPO_PUBLIC_SUPABASE_URL": "https://ptakhmjwuyfpnuxuqhow.supabase.co",
      "EXPO_PUBLIC_SUPABASE_ANON_KEY": "sb_publishable_Budzsr1vV3GDh7pSnvszdw_FWntiAte",
      "eas": {
        "projectId": "be10b52b-3f1b-45d9-8f8d-6efc7a27f46f"
      }
    },
    "owner": "janbestassistantever",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/be10b52b-3f1b-45d9-8f8d-6efc7a27f46f"
    }
  }
}
